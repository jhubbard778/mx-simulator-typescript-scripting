{
  "compilerOptions": {
    "target": "ES5",
    "ignoreDeprecations": "6.0",
    "module": "ESNext",      // Rollup handles modules, not tsc
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "outDir": "dist",
    "lib": ["ES5", "ES2015"],
    "rootDir": ".",
    "importHelpers": true
  },
  "include": ["src/**/*"]
}
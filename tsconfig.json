{
  "compilerOptions": {
    "target": "ES5",
    "ignoreDeprecations": "6.0",
    "module": "ESNext",      // Rollup handles modules, not tsc
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "outDir": "dist",
    "lib": [
      "ES5",
      "ES2016.Array.Include", // Manually polyfilled in polyfills/array.ts
    ],
    "rootDir": ".",
    "importHelpers": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "src/**/*",
    "examples/**/*",
    "types/**/*"
  ],
  "exclude": [
    "examples/**/dist/**/*"
  ]
}